# Copy this file to the repository root as ".env".
# Prisma runs inside packages/db; root scripts load ./.env so DATABASE_URL is always available.

# Database
DATABASE_URL="postgresql://quizmorph:quizmorph@localhost:5432/quizmorph?schema=public"

# Redis (BullMQ)
REDIS_URL="redis://localhost:6379"

# API
API_PORT=3001
API_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3000
FILE_STORAGE_PATH=./uploads

# Default page range for exam PDFs (1-based); ignored when PDF is pre-cropped
DEFAULT_PAGE_START=2
DEFAULT_PAGE_END=24

# Ollama (worker)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5vl:7b

# Worker: Python for PyMuPDF (defaults to apps/worker/.venv if present, else python3)
# PYTHON_EXECUTABLE=/absolute/path/to/apps/worker/.venv/bin/python3

# Google OAuth — used for sign-in and for creating Google Forms in the signed-in user’s Drive
# (Google Forms API). Add scope https://www.googleapis.com/auth/forms.body in Cloud Console
# OAuth consent screen, then have users sign in again so a refresh token is stored.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# Next.js
NEXT_PUBLIC_API_URL=http://localhost:3001

# JWT for API-issued bearer tokens (after Google OAuth callback)
JWT_SECRET=change-me-in-production

# Browser URL for OAuth redirect after Google login
FRONTEND_URL=http://localhost:3000
